rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isLoggedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // ─── USERS ───
    // Qualquer logado lê; só admin cria/deleta; usuário edita o próprio
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create, delete: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
    }

    // ─── USERNAMES ───
    // Leitura livre (necessário pro login por username)
    // Escrita só pelo admin ou no setup (quando não há admin ainda)
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // ─── BOOKS ───
    // Todos logados leem; só admin cria/edita
    match /books/{bookId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ─── REVIEWS ───
    // Todos logados leem; cada um escreve/edita só a própria avaliação
    match /reviews/{reviewId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() &&
        request.resource.data.authorId == request.auth.uid;
    }

    // ─── TOPICS ───
    // Todos logados leem e criam; só o autor ou admin edita/deleta
    match /topics/{topicId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── CONFIG (sorteio, etc) ───
    // Só admin lê e escreve
    match /config/{docId} {
      allow read, write: if isAdmin();
    }

  }
}
